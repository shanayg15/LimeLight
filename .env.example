# Copy to .env and fill in. Real secrets live in .env (gitignored); this file is committed.
# Most keys are blank until the milestone that needs them (noted inline).

# ── Core (needed from M1) ───────────────────────────────────────────────
# Local Docker Postgres maps host port 5446 -> container 5432 (see docker-compose.yml).
DATABASE_URL=postgresql://limelight:limelight@localhost:5446/limelight
AUTH_SECRET=            # openssl rand -base64 32
AUTH_URL=http://localhost:3012

# App-level encryption key for per-user provider keys stored in DB (used from M4).
ENCRYPTION_KEY=         # 32-byte base64: openssl rand -base64 32 — required before storing BYO keys

# ── Generation model (M2 prompt-gen, M3 detection, M6 content-gen) ──────
# BYO at the app level for self-host/dev; per-user keys override (added M4).
GENERATION_PROVIDER=anthropic        # anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Answer-engine keys (M3 Perplexity; M4 the rest). Per-user keys override. ──
PERPLEXITY_API_KEY=
GOOGLE_GENAI_API_KEY=

# ── Optional model overrides (sensible defaults if unset) ───────────────
# GENERATION_MODEL=claude-opus-4-8     # prompt/content generation
# DETECTION_MODEL=claude-haiku-4-5     # cheap structured mention detection
# PERPLEXITY_MODEL=sonar               # answer engine
# OPENAI_MODEL=gpt-4.1                 # answer engine (web_search)
# GEMINI_MODEL=gemini-2.5-flash        # answer engine (grounding)
# CLAUDE_ENGINE_MODEL=claude-haiku-4-5 # answer engine (web search)

# ── Email digests (M7) ──────────────────────────────────────────────────
RESEND_API_KEY=

# ── Inngest (M3+). Local dev needs neither key; production does. ─────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
